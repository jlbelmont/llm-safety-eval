# ---- Sensitive prompt data (avoid releasing adversarial datasets) ----
prompts/*.yaml
prompts/*.json
prompts/*.jsonl
prompts/*.csv
prompts/private/
prompts/generated/
!prompts/README.md
!src/llm_safety_eval/prompts/

# ---- Model weights/checkpoints (large) ----
models/
weights/
checkpoints/
*.bin
*.safetensors
*.pt
*.pth
*.gguf
*.onnx
.cache/huggingface/
~/.cache/huggingface/
.cache/torch/

# ---- Experiment outputs (regenerable) ----
runs/
!runs/.gitkeep
analysis_outputs/
results/
logs/
reports/

# ---- Notebook artifacts ----
notebooks/
.ipynb_checkpoints/

# ---- Environment / secrets ----
.env
.env.*
.venv/
.history/
secrets.yaml
configs/private.yaml

# ---- Local datasets ----
data/
datasets/
downloads/

# ---- Markdown docs (keep only readmes) ----
*.md
!README.md
*.jinja

# ---- Local course/reference materials ----
projectProgressReport.pdf
AuthorKit20/
report.tex
report.pdf
report.aux
report.out

# ---- Local auxiliary sources ----
*_drafts/
*_exports/
*_notes/
prompts/private_notes/

# ---- Generic LaTeX artifacts ----
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.nav
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb
*.xdv

# ---- Temp files ----
*.log
*.tmp
*.cache
*.pickle
*.pkl
scratch/
tmp/
experiments_tmp/
generated_prompts/
debug_scripts/

# ---- Report generation artifacts ----
# Generated outputs are ignored above.
# Note: ignore rules do not untrack files that are already committed.

# ---- Python build/cache ----
__pycache__/
*.pyc
*.pyo
*.pyd
build/
dist/
*.egg-info/

# ---- Editor / OS ----
.vscode/
.idea/
.DS_Store

# ---- Keep framework code visible ----
!src/
!docs/
!configs/
!tests/
!scripts/
!README.md
!LICENSE
!pyproject.toml
!Makefile
