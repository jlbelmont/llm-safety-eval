{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "version": {"type": "string"},
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {"type": "string"},
          "prompts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "prompt_id": {"type": "string"},
                "text": {"type": "string"},
                "safety_notes": {"type": "string"}
              },
              "required": ["prompt_id", "text"]
            }
          }
        },
        "required": ["prompts"]
      }
    }
  },
  "required": ["version", "categories"]
}
